{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index.html",
          "login.html",
          "lobby.html",
          "room.html",
          "trivia.html",
          "deploy.html",
          "contracts.js",
          "src/**"
        ]
      }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "index.js" }
  ]
}
